{
  "name": "starkive-app",
  "version": "1.0.0",
  "description": "Starkive — AES-256 file encryption with audit trail",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win appx",
    "build:dev": "electron-builder --win appx --config.win.certificateSubjectName=''"
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "electron-store": "^8.1.0",
    "node-7z-archive": "^1.1.2"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.starkive.app",
    "productName": "Starkive",
    "win": {
      "target": "appx",
      "icon": "assets/icon.png"
    },
    "appx": {
      "applicationId": "Starkive",
      "backgroundColor": "#111318",
      "displayName": "Starkive",
      "identityName": "Starkive.ZipEncrypt",
      "publisher": "CN=YourPublisherName",
      "publisherDisplayName": "Your Name",
      "languages": ["en-US"]
    }
  }
}
