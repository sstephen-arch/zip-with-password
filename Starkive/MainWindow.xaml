<Window x:Class="Starkive.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Starkive"
        Width="900" Height="620"
        MinWidth="800" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgPrimaryBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="DM Sans, IBM Plex Sans, Segoe UI, Arial"
        AllowDrop="True">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ SIDEBAR ══════════════════════════════════════════════════════════ -->
        <Border x:Name="SidebarBorder" Grid.Column="0"
                Width="210"
                Background="{DynamicResource BgSurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Hamburger -->
                <Button Grid.Row="0" x:Name="HamburgerBtn" Click="Hamburger_Click"
                        Style="{StaticResource NavButtonStyle}"
                        Margin="8,10,8,4" Height="32" HorizontalAlignment="Left" Width="36">
                    <TextBlock Text="&#x2630;" FontSize="14" Margin="10,0"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center"/>
                </Button>

                <!-- Logo -->
                <StackPanel Grid.Row="1" Orientation="Horizontal"
                            Margin="12,0,12,0" VerticalAlignment="Center">
                    <Border x:Name="LogoMark" Width="26" Height="26" CornerRadius="7"
                            Background="#EBF3FF">
                        <Canvas Width="26" Height="26" ClipToBounds="True">
                            <Ellipse Canvas.Left="3" Canvas.Top="3" Width="20" Height="20"
                                     Stroke="#0071E3" StrokeThickness="1.5" Fill="Transparent"/>
                            <Line X1="13" Y1="3"  X2="13" Y2="23" Stroke="#0071E3" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Line X1="3"  Y1="13" X2="23" Y2="13" Stroke="#0071E3" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Line X1="5.5" Y1="5.5" X2="20.5" Y2="20.5" Stroke="#0071E3" StrokeThickness="1.0" Opacity="0.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Line X1="20.5" Y1="5.5" X2="5.5" Y2="20.5" Stroke="#0071E3" StrokeThickness="1.0" Opacity="0.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Ellipse Canvas.Left="10" Canvas.Top="10" Width="6" Height="6" Fill="#0071E3"/>
                            <Ellipse Canvas.Left="11.2" Canvas.Top="11.2" Width="3.6" Height="3.6" Fill="#5AA8F0"/>
                        </Canvas>
                    </Border>
                    <TextBlock x:Name="LogoTextPanel"
                               Text="Starkive" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="9,0,0,0"/>
                </StackPanel>

                <!-- Nav items -->
                <StackPanel Grid.Row="3" x:Name="NavPanel" Margin="8,0">

                    <!-- SECTION LABEL -->
                    <TextBlock Text="MENU" FontSize="9" FontWeight="SemiBold"                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="10,0,0,6"/>

                    <!-- Home -->
                    <Button x:Name="NavHome" Click="Nav_Click" Tag="Home"
                            Style="{StaticResource NavButtonStyle}">
                        <Grid Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Width="15" Height="15" VerticalAlignment="Center">
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Border Grid.Row="0" Grid.Column="0" Margin="0,0,1.5,1.5" CornerRadius="1.5"
                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <Border Grid.Row="0" Grid.Column="1" Margin="1.5,0,0,1.5" CornerRadius="1.5"
                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <Border Grid.Row="1" Grid.Column="0" Margin="0,1.5,1.5,0" CornerRadius="1.5"
                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <Border Grid.Row="1" Grid.Column="1" Margin="1.5,1.5,0,0" CornerRadius="1.5"
                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </Grid>
                            <TextBlock x:Name="NavHomeText" Grid.Column="2"
                                       Text="Home" FontSize="12.5"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <!-- Zip & Encrypt -->
                    <Button x:Name="NavZip" Click="Nav_Click" Tag="Zip"
                            Style="{StaticResource NavButtonStyle}">
                        <Grid Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="NavZipIcon" Grid.Column="0"
                                       Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock x:Name="NavZipText" Grid.Column="2"
                                       Text="Zip &amp; Encrypt" FontSize="12.5"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <!-- Unzip & Decrypt -->
                    <Button x:Name="NavUnzip" Click="Nav_Click" Tag="Unzip"
                            Style="{StaticResource NavButtonStyle}">
                        <Grid Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="NavUnzipIcon" Grid.Column="0"
                                       Text="&#xF133;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock x:Name="NavUnzipText" Grid.Column="2"
                                       Text="Unzip &amp; Decrypt" FontSize="12.5"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <!-- History -->
                    <Button x:Name="NavHistory" Click="Nav_Click" Tag="History"
                            Style="{StaticResource NavButtonStyle}">
                        <Grid Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="NavHistoryIcon" Grid.Column="0"
                                       Text="&#xE81C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock x:Name="NavHistoryText" Grid.Column="2"
                                       Text="History" FontSize="12.5"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <!-- Settings -->
                    <Button x:Name="NavSettings" Click="Nav_Click" Tag="Settings"
                            Style="{StaticResource NavButtonStyle}">
                        <Grid Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="NavSettingsIcon" Grid.Column="0"
                                       Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock x:Name="NavSettingsText" Grid.Column="2"
                                       Text="Settings" FontSize="12.5"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <!-- Vault -->
                    <Button x:Name="NavVault" Click="Nav_Click" Tag="Vault"
                            Style="{StaticResource NavButtonStyle}">
                        <Grid Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="NavVaultIcon" Grid.Column="0"
                                       Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="NavVaultText"
                                           Text="Vault" FontSize="12.5"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           VerticalAlignment="Center"/>
                                <Border x:Name="NavVaultBadge" CornerRadius="8" Padding="5,1"
                                        Background="{DynamicResource AccentBrush}" Margin="6,0,0,0"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="NavVaultCount" Text="0" FontSize="9"
                                               FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- Footer -->
                <StackPanel Grid.Row="5" x:Name="SidebarFooter" Margin="0,0,0,4">

                    <!-- Divider -->
                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="12,0,12,10" Opacity="0.6"/>

                    <!-- Go Pro card -->
                    <Border x:Name="GoProBtn" CornerRadius="10" Margin="8,0,8,8" Cursor="Hand"
                            Background="{DynamicResource GoProBgBrush}"
                            BorderBrush="{DynamicResource GoProBorderBrush}" BorderThickness="1"
                            MouseLeftButtonUp="GoProBtn_Click">
                        <Border.Effect>
                            <DropShadowEffect Color="#7C3AED" BlurRadius="14" Opacity="0.3" ShadowDepth="0"/>
                        </Border.Effect>
                        <Grid Margin="11,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Header row -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="✦" Grid.Column="0" FontSize="12"
                                           Foreground="{DynamicResource ProTextBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="GoProLabel" Text="Starkive Pro" Grid.Column="1"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ProTextBrush}" Margin="7,0,0,0" VerticalAlignment="Center"/>
                                <Border Grid.Column="2" CornerRadius="3" Padding="5,1"
                                        Background="{DynamicResource ProBadgeBgBrush}">
                                    <TextBlock x:Name="GoProPrice" Text="$2.99/mo"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ProTextBrush}"/>
                                </Border>
                            </Grid>
                            <!-- Feature bullets -->
                            <StackPanel Grid.Row="2">
                                <TextBlock FontSize="10" Foreground="{DynamicResource ProSubTextBrush}" Margin="0,1">
                                    <Run Text="✓ "/>
                                    <Run Text="Secure Container (.ssz)"/>
                                </TextBlock>
                                <TextBlock FontSize="10" Foreground="{DynamicResource ProSubTextBrush}" Margin="0,1">
                                    <Run Text="✓ "/>
                                    <Run Text="Open notifications + PDF"/>
                                </TextBlock>
                                <TextBlock FontSize="10" Foreground="{DynamicResource ProSubTextBrush}" Margin="0,1">
                                    <Run Text="✓ "/>
                                    <Run Text="Cloud Drive sync"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Version -->
                    <StackPanel x:Name="VersionPanel" Orientation="Horizontal"
                                Margin="14,0,0,8" VerticalAlignment="Center">
                        <Ellipse Width="5" Height="5" Fill="#22C55E" VerticalAlignment="Center"/>
                        <TextBlock x:Name="VersionText" Text="v1.3.4" FontSize="10"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontFamily="Consolas" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Hidden accent rectangles (kept for code-behind nav highlight logic) -->
                <Canvas Visibility="Collapsed">
                    <Rectangle x:Name="NavHomeAccent"/>
                    <Rectangle x:Name="NavZipAccent"/>
                    <Rectangle x:Name="NavUnzipAccent"/>
                    <Rectangle x:Name="NavHistoryAccent"/>
                    <Rectangle x:Name="NavSettingsAccent"/>
                    <Rectangle x:Name="NavVaultAccent"/>
                </Canvas>

            </Grid>
        </Border>

        <!-- 
             CONTENT AREA
         -->
        <Grid Grid.Column="1" Background="{DynamicResource BgPrimaryBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Update banner -->
            <Border x:Name="UpdateBanner"
                    Grid.Row="0"
                    Background="{DynamicResource BannerInfoBgBrush}" BorderBrush="#1A56DB" BorderThickness="0,0,0,1"
                    Padding="20,10" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="UpdateBannerText"
                               Grid.Column="0" FontSize="12"
                               Foreground="#7AB3F5" VerticalAlignment="Center"/>
                    <Button x:Name="UpdateDownloadBtn"
                            Grid.Column="1" Content="Download"
                            Style="{StaticResource GhostButtonStyle}"
                            FontSize="11" Padding="12,4" Margin="12,0,0,0"
                            Click="UpdateDownload_Click"/>
                    <Button Grid.Column="2" Content="X"
                            Style="{StaticResource GhostButtonStyle}"
                            FontSize="11" Padding="8,4" Margin="4,0,0,0"
                            Click="UpdateDismiss_Click"/>
                </Grid>
            </Border>

            <!-- All sections in row 1 -->
            <Grid Grid.Row="1">

            <!--   HOME SECTION   -->
            <Grid x:Name="HomeSection">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Hero Header with gradient -->
                <Border Grid.Row="0" Background="{DynamicResource HeroGradientBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid Margin="28,22,28,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="HomeGreeting" Text="Good morning" FontSize="22" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Protect, share, and track your files with confidence."
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        <!-- Quick CTA -->
                        <Button Grid.Column="1" Content="+ New Container"
                                Style="{StaticResource PrimaryButtonStyle}"
                                FontSize="12" Padding="16,8"
                                Click="HomeCardPro_Click"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Body -->
                <ScrollViewer Grid.Row="1" Margin="0,0,0,0"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="28,20,28,28">

                        <!-- Quick Actions -->
                        <TextBlock Text="QUICK ACTIONS" FontSize="10" FontWeight="SemiBold"                                   Foreground="{DynamicResource TextLabelBrush}"
                                   Margin="0,0,0,10"/>

                        <!-- 2x2 action grid -->
                        <UniformGrid Rows="2" Columns="2" Margin="0,0,0,20">

                            <!-- Card 1: Zip & Encrypt -->
                            <Border Margin="0,0,6,6" CornerRadius="12"
                                    Background="{DynamicResource BgCardBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" Cursor="Hand"
                                    MouseLeftButtonUp="HomeCardZip_Click">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000" BlurRadius="12" Opacity="0.2" ShadowDepth="1" Direction="270"/>
                                </Border.Effect>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid Margin="16,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="38" Height="38"
                                            CornerRadius="10" Background="{DynamicResource IconBgBlueBrush}">
                                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="17" Foreground="#0071E3"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="13,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Zip &amp; Encrypt" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="AES-256 password protection" FontSize="11"
                                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="›" FontSize="18"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center" Opacity="0.5"/>
                                </Grid>
                            </Border>

                            <!-- Card 2: Unzip & Decrypt -->
                            <Border Margin="6,0,0,6" CornerRadius="12"
                                    Background="{DynamicResource BgCardBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" Cursor="Hand"
                                    MouseLeftButtonUp="HomeCardUnzip_Click">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000" BlurRadius="12" Opacity="0.2" ShadowDepth="1" Direction="270"/>
                                </Border.Effect>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid Margin="16,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="38" Height="38"
                                            CornerRadius="10" Background="{DynamicResource IconBgGreenBrush}">
                                        <TextBlock Text="&#xF133;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="17" Foreground="#22C55E"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="13,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Unzip &amp; Decrypt" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Extract protected archives" FontSize="11"
                                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="›" FontSize="18"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center" Opacity="0.5"/>
                                </Grid>
                            </Border>

                            <!-- Card 3: Secure Container (Pro) -->
                            <Border x:Name="HomeCardSecureContainer"
                                    Margin="0,6,6,0" CornerRadius="12"
                                    Background="{DynamicResource BgCardBrush}"
                                    BorderBrush="#5B21B6" BorderThickness="1"
                                    Cursor="Hand" MouseLeftButtonUp="HomeCardPro_Click">
                                <Border.Effect>
                                    <DropShadowEffect Color="#7C3AED" BlurRadius="14" Opacity="0.2" ShadowDepth="0"/>
                                </Border.Effect>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid Margin="16,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="38" Height="38"
                                            CornerRadius="10" Background="{DynamicResource IconBgPurpleBrush}">
                                        <TextBlock Text="&#xE83D;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="17" Foreground="#C084FC"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="13,0,0,0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                            <TextBlock Text="Secure Container" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <Border x:Name="HomeCardProBadge"
                                                    Margin="8,0,0,0" CornerRadius="4" Padding="5,1"
                                                    Background="#2A1060">
                                                <TextBlock Text="PRO" FontSize="9" FontWeight="Bold" Foreground="#A855F7"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="Know when your file is opened" FontSize="11"
                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="›" FontSize="18"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center" Opacity="0.5"/>
                                </Grid>
                            </Border>

                            <!-- Card 4: History -->
                            <Border Margin="6,6,0,0" CornerRadius="12"
                                    Background="{DynamicResource BgCardBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" Cursor="Hand"
                                    MouseLeftButtonUp="HomeCardHistory_Click">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000" BlurRadius="12" Opacity="0.2" ShadowDepth="1" Direction="270"/>
                                </Border.Effect>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid Margin="16,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="38" Height="38"
                                            CornerRadius="10" Background="{DynamicResource IconBgAmberBrush}">
                                        <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="17" Foreground="#F59E0B"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="13,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="History" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="View recent operations" FontSize="11"
                                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="›" FontSize="18"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center" Opacity="0.5"/>
                                </Grid>
                            </Border>
                        </UniformGrid>

                        <!-- Pro upsell strip — hidden for Pro users -->
                        <Border x:Name="HomeProUpsellStrip"
                                CornerRadius="12" Margin="0,0,0,16"
                                BorderBrush="{DynamicResource GoProBorderBrush}" BorderThickness="1"
                                Background="{DynamicResource BgCardBrush}">
                            <Border.Effect>
                                <DropShadowEffect Color="#7C3AED" BlurRadius="14" Opacity="0.15" ShadowDepth="0"/>
                            </Border.Effect>
                            <Grid Margin="18,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <Border CornerRadius="4" Padding="6,2" Background="{DynamicResource ProBadgeBgBrush}" Margin="0,0,8,0">
                                            <TextBlock Text="PRO" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ProTextBrush}"/>
                                        </Border>
                                        <TextBlock Text="Unlock the full Starkive experience" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✓" Foreground="{DynamicResource ProTextBrush}" FontSize="11" Margin="0,0,5,0"/>
                                        <TextBlock Text="Open tracking + email alerts" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,0,16,0"/>
                                        <TextBlock Text="✓" Foreground="{DynamicResource ProTextBrush}" FontSize="11" Margin="0,0,5,0"/>
                                        <TextBlock Text="Cloud backup" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,0,16,0"/>
                                        <TextBlock Text="✓" Foreground="{DynamicResource ProTextBrush}" FontSize="11" Margin="0,0,5,0"/>
                                        <TextBlock Text="SSZ sharing" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Upgrade →"
                                        VerticalAlignment="Center" Margin="16,0,0,0"
                                        Padding="16,8" FontSize="12" FontWeight="SemiBold"
                                        Cursor="Hand"
                                        Click="HomeCardPro_Click">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                            <GradientStop Color="#A855F7" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                    <Button.Foreground>
                                        <SolidColorBrush Color="White"/>
                                    </Button.Foreground>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Pro Active ribbon — shown only for Pro subscribers -->
                        <Border x:Name="HomeProActiveStrip"
                                CornerRadius="12" Margin="0,0,0,16"
                                BorderThickness="0"
                                Visibility="Collapsed">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.4">
                                    <GradientStop Color="#6D28D9" Offset="0"/>
                                    <GradientStop Color="#7C3AED" Offset="0.55"/>
                                    <GradientStop Color="#9333EA" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#7C3AED" BlurRadius="18" Opacity="0.35" ShadowDepth="0"/>
                            </Border.Effect>
                            <Grid Margin="18,13">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Sparkle medallion -->
                                <Border Grid.Column="0" Width="38" Height="38" CornerRadius="19"
                                        Margin="0,0,14,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="White" Opacity="0.18"/>
                                    </Border.Background>
                                    <TextBlock Text="✦" FontSize="17" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <TextBlock Text="Starkive Pro" FontSize="14" FontWeight="Bold"
                                                   Foreground="White" VerticalAlignment="Center"/>
                                        <Border CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                                VerticalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="White" Opacity="0.22"/>
                                            </Border.Background>
                                            <TextBlock Text="ACTIVE" FontSize="8.5" FontWeight="Bold"
                                                       Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✓ Secure Container" Foreground="#E9DEFF" FontSize="11" Margin="0,0,14,0"/>
                                        <TextBlock Text="✓ Open notifications" Foreground="#E9DEFF" FontSize="11" Margin="0,0,14,0"/>
                                        <TextBlock Text="✓ Cloud sync" Foreground="#E9DEFF" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Column="2" CornerRadius="8" Padding="14,7"
                                        Background="White" Margin="16,0,0,0"
                                        Cursor="Hand" MouseLeftButtonUp="GoProBtn_Click">
                                    <TextBlock Text="Manage →" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#6D28D9"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Drop zone (secondary) -->
                        <Grid Margin="0,0,0,16" MinHeight="64">
                            <Rectangle x:Name="HomeDropRect"
                                       Stroke="#0071E3"
                                       StrokeThickness="1.5" StrokeDashArray="5 4"
                                       RadiusX="10" RadiusY="10"
                                       Opacity="0.35"
                                       IsHitTestVisible="False"/>
                            <Border x:Name="HomeDropZone" CornerRadius="10"
                                    Background="{DynamicResource BgCardBrush}"
                                    Cursor="Hand" AllowDrop="True" MinHeight="64"
                                    Drop="HomeDropZone_Drop"
                                    DragOver="DropZone_DragOver"
                                    DragEnter="HomeDropZone_DragEnter"
                                    DragLeave="HomeDropZone_DragLeave"
                                    Opacity="0.7">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0,18">
                                    <Border Width="28" Height="28" CornerRadius="6"
                                            Background="{DynamicResource IconBgBlueBrush}"
                                            VerticalAlignment="Center" Margin="0,0,10,0">
                                        <Canvas Width="16" Height="16"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Line X1="8" Y1="13" X2="8" Y2="3"
                                                  Stroke="#0071E3" StrokeThickness="1.6"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Polyline Points="4,7 8,3 12,7"
                                                      Stroke="#0071E3" StrokeThickness="1.6"
                                                      StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round" Fill="Transparent"/>
                                            <Line X1="2" Y1="14" X2="14" Y2="14"
                                                  Stroke="#0071E3" StrokeThickness="1.4"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Opacity="0.5"/>
                                        </Canvas>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Drop any file here to compress"
                                                   FontSize="12" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text="or click Zip &amp; Encrypt to browse"
                                                   FontSize="10.5"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Section: Recent -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="RECENT ACTIVITY" FontSize="10" FontWeight="SemiBold"                                       Foreground="{DynamicResource TextLabelBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="View all →" FontSize="11"
                                       Foreground="#0071E3" VerticalAlignment="Center"
                                       Cursor="Hand" MouseLeftButtonUp="HomeCardHistory_Click"/>
                        </Grid>
                        <ItemsControl x:Name="HomeRecentList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8"
                                            Background="{DynamicResource BgCardBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            Padding="14,10" Margin="0,0,0,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="30" Height="30"
                                                    CornerRadius="6" Margin="0,0,10,0"
                                                    Background="{DynamicResource IconBgBlueBrush}">
                                                <TextBlock Text="{Binding TypeIcon}"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="14"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding OutputPath}"
                                                           FontSize="12" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding FormattedTime}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="&#x203A;" FontSize="14"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                                       Opacity="0.5"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="HomeRecentEmpty"
                                   Text="No recent operations yet."
                                   FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,4,0,0" Visibility="Collapsed"/>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!--   ZIP SECTION   -->
            <ScrollViewer x:Name="ZipSection" VerticalScrollBarVisibility="Auto"
                          Background="Transparent" Visibility="Collapsed">
                <StackPanel>

                    <!-- Header -->
                    <StackPanel Margin="22,12,22,0">
                        <TextBlock Text="Zip &amp; Encrypt" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="Add files or folders, set a password, create an AES-256 encrypted archive."
                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Body -->
                    <StackPanel Margin="28,10,28,12">

                        <!-- Drop zone -->
                        <Grid Margin="0,0,0,8" MinHeight="110">
                            <Rectangle x:Name="ZipDropRect"
                                       Stroke="{DynamicResource BorderBrush}"
                                       StrokeThickness="1.5" StrokeDashArray="4 3"
                                       RadiusX="8" RadiusY="8"
                                       IsHitTestVisible="False"/>
                            <Border x:Name="DropZone" CornerRadius="8"
                                    Background="Transparent"
                                    AllowDrop="True"
                                    Drop="DropZone_Drop"
                                    DragOver="DropZone_DragOver"
                                    DragLeave="DropZone_DragLeave"
                                    DragEnter="DropZone_DragEnter">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,14,0,14">
                                    <Canvas Width="24" Height="24" Margin="0,0,0,8"
                                            HorizontalAlignment="Center">
                                        <Line X1="12" Y1="20" X2="12" Y2="6"
                                              Stroke="#1A56DB" StrokeThickness="1.8"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        <Polyline Points="7,11 12,6 17,11"
                                                  Stroke="#1A56DB" StrokeThickness="1.8"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round" Fill="Transparent"/>
                                        <Line X1="5" Y1="20" X2="19" Y2="20"
                                              Stroke="#1A56DB" StrokeThickness="1.8"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Opacity="0.4"/>
                                    </Canvas>
                                    <TextBlock Text="Drop files or folders here"
                                               FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="or" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center" Margin="0,3"/>
                                    <Button Content="Browse files"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Padding="14,6" FontSize="12"
                                            HorizontalAlignment="Center"
                                            Click="ZipBrowseSource_Click"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- SOURCE card -->
                        <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="14,10" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="SOURCE" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextLabelBrush}"
                                           Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ZipSourceBox"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             IsReadOnly="True"
                                             Text="No file or folder selected"/>
                                    <Button Grid.Column="1" Content="Change"
                                            Style="{StaticResource InlineButtonStyle}"
                                            Margin="6,0,0,0"
                                            Click="ZipBrowseSource_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- SAVE TO card — always visible, shows all destinations -->
                        <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="14,10" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="SAVE TO" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextLabelBrush}"
                                           Margin="0,0,0,7"/>

                                <!-- Three destination tiles always visible -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Local -->
                                    <Border x:Name="DestTileLocal" Grid.Column="0"
                                            CornerRadius="8" Padding="10,7"
                                            BorderThickness="2" Cursor="Hand"
                                            MouseLeftButtonDown="DestTile_Click" Tag="Local">
                                        <StackPanel>
                                            <TextBlock Text="💾" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                            <TextBlock Text="Local Folder" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="DestLocalSub" FontSize="10"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       HorizontalAlignment="Center" TextWrapping="Wrap"
                                                       TextAlignment="Center" Margin="0,3,0,0"
                                                       Text="Save to your computer"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Google Drive -->
                                    <Border x:Name="DestTileGDrive" Grid.Column="2"
                                            CornerRadius="8" Padding="10,7"
                                            BorderThickness="2" Cursor="Hand"
                                            MouseLeftButtonDown="DestTile_Click" Tag="GoogleDrive">
                                        <StackPanel>
                                            <TextBlock Text="G" FontSize="18" FontWeight="Bold"
                                                       Foreground="#4285F4"
                                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                            <TextBlock Text="Google Drive" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="DestGDriveSub" FontSize="10"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       HorizontalAlignment="Center" TextWrapping="Wrap"
                                                       TextAlignment="Center" Margin="0,3,0,0"
                                                       Text="Not connected"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- OneDrive -->
                                    <Border x:Name="DestTileOneDrive" Grid.Column="4"
                                            CornerRadius="8" Padding="12,10"
                                            BorderThickness="2" Cursor="Hand"
                                            MouseLeftButtonDown="DestTile_Click" Tag="OneDrive">
                                        <StackPanel>
                                            <TextBlock Text="☁" FontSize="18"
                                                       Foreground="#0078D4"
                                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                            <TextBlock Text="OneDrive" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="DestOneDriveSub" FontSize="10"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       HorizontalAlignment="Center" TextWrapping="Wrap"
                                                       TextAlignment="Center" Margin="0,3,0,0"
                                                       Text="Not connected"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Local path row — shown when Local is selected -->
                                <Grid x:Name="LocalPathRow" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ZipOutputBox"
                                             Style="{StaticResource DarkTextBoxStyle}"/>
                                    <Button Grid.Column="1" Content="Browse"
                                            Style="{StaticResource InlineButtonStyle}"
                                            Margin="6,0,0,0"
                                            Click="ZipBrowseOutput_Click"/>
                                </Grid>

                                <!-- Cloud info row — shown when cloud is selected -->
                                <Border x:Name="CloudDestRow"
                                        Background="{DynamicResource BgInputBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="12,10" Margin="0,12,0,0" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock x:Name="CloudDestTitle"
                                                   FontSize="12" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock x:Name="CloudDestSubtitle"
                                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                                   Margin="0,3,0,0" TextWrapping="Wrap"/>
                                        <Button x:Name="CloudDestConnectBtn"
                                                Content="Connect in Settings →"
                                                Style="{StaticResource GhostButtonStyle}"
                                                FontSize="11" Padding="0,4,0,0"
                                                HorizontalAlignment="Left"
                                                Visibility="Collapsed"
                                                Click="CloudDestConnectBtn_Click"/>
                                    </StackPanel>
                                </Border>

                                <!-- Hidden segment buttons kept for code compatibility -->
                                <StackPanel Visibility="Collapsed">
                                    <Button x:Name="BtnDestLocal"  Tag="Local"/>
                                    <Button x:Name="BtnDestGDrive" Tag="GoogleDrive"/>
                                    <Button x:Name="BtnDestOneDrive" Tag="OneDrive"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- OUTPUT FORMAT card -->
                        <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="14,10" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="OUTPUT FORMAT" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextLabelBrush}"
                                           Margin="0,0,0,5"/>
                                <Border Background="{DynamicResource BgInputBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BtnFmtZip" Grid.Column="0"
                                                Content="Encrypted ZIP" Tag="ZIP"
                                                Style="{StaticResource SegmentButtonStyle}"
                                                Click="OutputFmt_Click"/>
                                        <Button x:Name="BtnFmtSsz" Grid.Column="1"
                                                Tag="SSZ"
                                                Style="{StaticResource SegmentButtonStyle}"
                                                Click="OutputFmt_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Secure Container" VerticalAlignment="Center"/>
                                                <Border Margin="5,0,0,0" CornerRadius="3"
                                                        Background="{DynamicResource IconBgPurpleBrush}" Padding="4,1">
                                                    <TextBlock Text="PRO" FontSize="9" FontWeight="Bold"
                                                               Foreground="#C084FC"/>
                                                </Border>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Recipient hint — shown only in SSZ mode -->
                                <StackPanel x:Name="RecipientHintPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="RECIPIENT" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextLabelBrush}"/>
                                        <TextBlock Text=" — optional" FontSize="10"
                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                    </StackPanel>
                                    <TextBox x:Name="RecipientHintBox"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             Text="" MaxLength="120"
                                             ToolTip="Who is this for? e.g. 'John at Acme' — shown in the open notification email you receive."/>
                                    <TextBlock Text="Shown in your notification email when the file is opened."
                                               FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- PASSWORD MODE card (Fix 4d) -->
                        <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="14,10" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="PASSWORD MODE" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextLabelBrush}"
                                           Margin="0,0,0,5"/>
                                <Border Background="{DynamicResource BgInputBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BtnModePassword" Grid.Column="0"
                                                Content="Password" Tag="Password"
                                                Style="{StaticResource SegmentButtonStyle}"
                                                Click="PwdMode_Click"/>
                                        <Button x:Name="BtnModePassphrase" Grid.Column="1"
                                                Content="Passphrase" Tag="Passphrase"
                                                Style="{StaticResource SegmentButtonStyle}"
                                                Click="PwdMode_Click"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!--   MODE: PASSWORD   -->
                        <StackPanel x:Name="PwdPanelPassword">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="PASSWORD" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextLabelBrush}"
                                               Margin="0,0,0,3"/>
                                    <Border Background="{DynamicResource BgCardBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="10">
                                        <PasswordBox x:Name="ZipPasswordBox"
                                                     Style="{StaticResource DarkPasswordBoxStyle}"
                                                     PasswordChanged="ZipPassword_Changed"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="CONFIRM PASSWORD" FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextLabelBrush}"
                                               Margin="0,0,0,3"/>
                                    <Border Background="{DynamicResource BgCardBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="10">
                                        <PasswordBox x:Name="ZipConfirmBox"
                                                     Style="{StaticResource DarkPasswordBoxStyle}"
                                                     PasswordChanged="ZipPassword_Changed"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Strength bar -->
                            <Grid Margin="0,6,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Height="3" CornerRadius="1.5"
                                        Background="{DynamicResource BorderBrush}"
                                        VerticalAlignment="Center">
                                    <Border x:Name="StrengthBar" CornerRadius="1.5"
                                            Background="{DynamicResource AccentBrush}"
                                            HorizontalAlignment="Left" Width="0"/>
                                </Border>
                                <TextBlock Grid.Column="1" x:Name="StrengthLabel"
                                           Text="--" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock x:Name="EntropyLabel" FontSize="10"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,2,0,0"/>
                            <Border x:Name="WeakPasswordWarning"
                                    Background="{DynamicResource BannerWarnBgBrush}" BorderBrush="#7C2D12"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="10,7" Margin="0,8,0,0"
                                    Visibility="Collapsed">
                                <TextBlock TextWrapping="Wrap" FontSize="11"
                                           Foreground="#FCA47A">
                                    <Run FontWeight="SemiBold">Weak password.</Run>
                                    <Run>WinZip AES uses only 1,000 PBKDF2 rounds — a short or common password can be brute-forced quickly. Use the passphrase mode or generate a strong password below.</Run>
                                </TextBlock>
                            </Border>

                            <!-- Auto-generate section (inline, collapsible) -->
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                                    Margin="0,8,0,0" Padding="0,8,0,0">
                                <StackPanel>
                                    <Button x:Name="BtnAutoGenToggle"
                                            Content="&#x2022;&#x2022;&#x2022; Generate a strong password for me"
                                            Style="{StaticResource InlineButtonStyle}"
                                            HorizontalAlignment="Left" FontSize="12"
                                            Click="AutoGenToggle_Click"/>
                                    <StackPanel x:Name="AutoGenPanel" Visibility="Collapsed" Margin="0,10,0,0">
                                        <TextBlock Text="GENERATED PASSWORD" FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextLabelBrush}"
                                                   Margin="0,0,0,5"/>
                                        <Border Background="{DynamicResource BgCardBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="10" Margin="0,0,0,10">
                                            <TextBox x:Name="AutoGenDisplay"
                                                     Style="{StaticResource MonoDisplayStyle}"/>
                                        </Border>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <CheckBox x:Name="ChkUpper" Content="Uppercase" IsChecked="True"
                                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                                      FontSize="12" Margin="0,0,14,0"
                                                      Checked="AutoGenOption_Changed"
                                                      Unchecked="AutoGenOption_Changed"/>
                                            <CheckBox x:Name="ChkLower" Content="Lowercase" IsChecked="True"
                                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                                      FontSize="12" Margin="0,0,14,0"
                                                      Checked="AutoGenOption_Changed"
                                                      Unchecked="AutoGenOption_Changed"/>
                                            <CheckBox x:Name="ChkDigits" Content="Digits" IsChecked="True"
                                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                                      FontSize="12" Margin="0,0,14,0"
                                                      Checked="AutoGenOption_Changed"
                                                      Unchecked="AutoGenOption_Changed"/>
                                            <CheckBox x:Name="ChkSpecial" Content="Symbols" IsChecked="True"
                                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                                      FontSize="12"
                                                      Checked="AutoGenOption_Changed"
                                                      Unchecked="AutoGenOption_Changed"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Slider x:Name="LengthSlider" Minimum="8" Maximum="64" Value="16"
                                                    Width="160" VerticalAlignment="Center"
                                                    ValueChanged="LengthSlider_Changed"/>
                                            <TextBlock x:Name="LengthLabel" Text="16 characters" FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="&#x21BB; Regenerate"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Padding="12,7" FontSize="12"
                                                    Click="RegenerateAutoPassword_Click"/>
                                            <Button Content="Copy"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Padding="12,7" FontSize="12" Margin="8,0,0,0"
                                                    Click="CopyAutoPassword_Click"/>
                                            <Button Content="Use this password"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Padding="12,7" FontSize="12" Margin="8,0,0,0"
                                                    Click="UseAutoPassword_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Save to this device -->
                            <CheckBox x:Name="ChkSavePassword"
                                      Content="Save password to this device"
                                      IsChecked="False"
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      FontSize="12" Margin="0,12,0,0"/>
                        </StackPanel>

                        <!--   MODE: PASSPHRASE   -->
                        <StackPanel x:Name="PwdPanelPassphrase" Visibility="Collapsed">
                            <TextBlock Text="GENERATED PASSPHRASE" FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextLabelBrush}"
                                       Margin="0,0,0,5"/>
                            <Border Background="{DynamicResource BgCardBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="10" Margin="0,0,0,10">
                                <TextBox x:Name="PassphraseDisplay"
                                         Style="{StaticResource MonoDisplayStyle}"/>
                            </Border>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{DynamicResource BgInputBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="2">
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="Btn3Words" Content="3 words" Tag="3"
                                                Style="{StaticResource SegmentButtonStyle}"
                                                Click="WordCount_Click" Padding="8,5"/>
                                        <Button x:Name="Btn4Words" Content="4 words" Tag="4"
                                                Style="{StaticResource SegmentButtonStyle}"
                                                Click="WordCount_Click" Padding="8,5"/>
                                        <Button x:Name="Btn5Words" Content="5 words" Tag="5"
                                                Style="{StaticResource SegmentButtonStyle}"
                                                Click="WordCount_Click" Padding="8,5"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="{DynamicResource BgInputBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="2">
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="BtnSepDot" Content="&#xB7;" Tag="&#xB7;"
                                                Style="{StaticResource SegmentButtonStyle}"
                                                Click="Separator_Click" Padding="10,5"/>
                                        <Button x:Name="BtnSepDash" Content="-" Tag="-"
                                                Style="{StaticResource SegmentButtonStyle}"
                                                Click="Separator_Click" Padding="10,5"/>
                                        <Button x:Name="BtnSepSpace" Content="space" Tag=" "
                                                Style="{StaticResource SegmentButtonStyle}"
                                                Click="Separator_Click" Padding="8,5"/>
                                    </StackPanel>
                                </Border>
                                <Button Grid.Column="4" Content="&#x21BB; New passphrase"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Padding="12,7" FontSize="12"
                                        Click="RegeneratePassphrase_Click"/>
                                <Button Grid.Column="6" x:Name="CopyPassphraseBtn"
                                        Content="Copy"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Padding="12,7" FontSize="12"
                                        Click="CopyPassphrase_Click"/>
                            </Grid>
                            <!-- Save to this device -->
                            <CheckBox x:Name="ChkSavePassphrase"
                                      Content="Save passphrase to this device"
                                      IsChecked="False"
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      FontSize="12" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- Create ZIP button -->
                        <Button x:Name="ZipCreateButton" Content="Create Encrypted ZIP"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,18,0,0" HorizontalAlignment="Stretch"
                                Click="ZipCreate_Click"/>
                        <Grid x:Name="ZipProgressPanel" Margin="0,10,0,0" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Height="4" CornerRadius="2"
                                    Background="{DynamicResource BorderBrush}">
                                <Border x:Name="ZipProgressBar" CornerRadius="2"
                                        Background="{DynamicResource AccentBrush}"
                                        HorizontalAlignment="Left" Width="0"/>
                            </Border>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock x:Name="ZipPercentText" Text="0%" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="ZipStatusText" Text="" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="ZipErrorText" FontSize="12"
                                   Foreground="{DynamicResource DangerBrush}"
                                   TextWrapping="Wrap" Margin="0,10,0,0"
                                   Visibility="Collapsed"/>
                        <Border x:Name="ZipSuccessBanner"
                                Background="{DynamicResource BannerSuccessBgBrush}" BorderBrush="{DynamicResource SuccessBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="14,12"
                                Margin="0,10,0,0" Visibility="Collapsed">
                            <StackPanel>
                                <!-- Status row -->
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✓" FontSize="13"
                                               Foreground="{DynamicResource SuccessBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ZipSuccessText"
                                               Text="ZIP created successfully."
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Cloud upload row — shown only when SSZ + Drive connected -->
                                <StackPanel x:Name="CloudUploadPanel" Orientation="Horizontal"
                                            Margin="0,10,0,0" Visibility="Collapsed">
                                    <TextBlock Text="Upload to:"
                                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button x:Name="UploadGDriveBtn" Content="☁ Google Drive"
                                            FontSize="11" Padding="10,4" Margin="0,0,8,0"
                                            Click="UploadGDriveBtn_Click"/>
                                    <Button x:Name="UploadOneDriveBtn" Content="☁ OneDrive"
                                            FontSize="11" Padding="10,4"
                                            Click="UploadOneDriveBtn_Click"/>
                                </StackPanel>

                                <!-- Upload result row -->
                                <StackPanel x:Name="CloudUploadResultPanel" Orientation="Horizontal"
                                            Margin="0,8,0,0" Visibility="Collapsed">
                                    <TextBlock x:Name="CloudUploadResultText"
                                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center"/>
                                    <Button x:Name="CopyCloudLinkBtn" Content="Copy Link"
                                            FontSize="11" Padding="8,3" Margin="10,0,0,0"
                                            Click="CopyCloudLinkBtn_Click" Visibility="Collapsed"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- UNZIP SECTION -->
            <ScrollViewer x:Name="UnzipSection" VerticalScrollBarVisibility="Auto"
                          Background="Transparent" Visibility="Collapsed">
                <StackPanel>
                    <StackPanel Margin="22,12,22,0">
                        <TextBlock Text="Unzip &amp; Decrypt" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,3"/>
                        <TextBlock Text="Select an AES-256 encrypted ZIP, enter the password, and extract."
                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Margin="28,10,28,12">
                        <Grid Margin="0,0,0,8" Height="76">
                            <Rectangle Stroke="{DynamicResource BorderBrush}"
                                       StrokeThickness="1.5" StrokeDashArray="4 3"
                                       RadiusX="8" RadiusY="8" IsHitTestVisible="False"/>
                            <Border x:Name="UnzipDropZone" CornerRadius="8"
                                    Background="Transparent" AllowDrop="True"
                                    Drop="UnzipDropZone_Drop"
                                    DragOver="DropZone_DragOver"
                                    DragLeave="UnzipDropZone_DragLeave"
                                    DragEnter="UnzipDropZone_DragEnter">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="Drop a .zip file here" FontSize="12"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="or" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center" Margin="0,3"/>
                                    <Button Content="Browse files"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Padding="14,6" FontSize="12"
                                            HorizontalAlignment="Center"
                                            Click="UnzipBrowseSource_Click"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="14,10" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="ZIP FILE" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextLabelBrush}"
                                           Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="UnzipSourceBox"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             IsReadOnly="True" Text="No file selected"/>
                                    <Button Grid.Column="1" Content="Change"
                                            Style="{StaticResource InlineButtonStyle}"
                                            Margin="6,0,0,0"
                                            Click="UnzipBrowseSource_Click"/>
                                </Grid>
                                <Rectangle Height="1" Fill="#152030" Margin="0,8"/>
                                <TextBlock Text="EXTRACT TO" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextLabelBrush}"
                                           Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="UnzipOutputBox"
                                             Style="{StaticResource DarkTextBoxStyle}"/>
                                    <Button Grid.Column="1" Content="Browse"
                                            Style="{StaticResource InlineButtonStyle}"
                                            Margin="6,0,0,0"
                                            Click="UnzipBrowseOutput_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="14,10" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="PASSWORD" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextLabelBrush}"
                                           Margin="0,0,0,3"/>
                                <Border Background="{DynamicResource BgCardBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="10">
                                    <PasswordBox x:Name="UnzipPasswordBox"
                                                 Style="{StaticResource DarkPasswordBoxStyle}"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Button x:Name="UnzipButton" Content="Extract &amp; Decrypt"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Stretch" Click="Unzip_Click"/>
                        <Grid x:Name="UnzipProgressPanel" Margin="0,10,0,0" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Height="4" CornerRadius="2"
                                    Background="{DynamicResource BorderBrush}">
                                <Border x:Name="UnzipProgressBar" CornerRadius="2"
                                        Background="{DynamicResource AccentBrush}"
                                        HorizontalAlignment="Left" Width="0"/>
                            </Border>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock x:Name="UnzipPercentText" Text="0%" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="UnzipStatusText" Text="" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="UnzipErrorText" FontSize="12"
                                   Foreground="{DynamicResource DangerBrush}"
                                   TextWrapping="Wrap" Margin="0,10,0,0"
                                   Visibility="Collapsed"/>
                        <Border x:Name="UnzipSuccessBanner"
                                Background="{DynamicResource BannerSuccessBgBrush}" BorderBrush="{DynamicResource SuccessBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="14,12"
                                Margin="0,10,0,0" Visibility="Collapsed">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✓" FontSize="13"
                                               Foreground="{DynamicResource SuccessBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Extraction complete." FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Sent by — only visible for SSZ files when creator identity is known -->
                                <StackPanel x:Name="UnzipSentByPanel" Orientation="Horizontal"
                                            Margin="0,6,0,0" Visibility="Collapsed">
                                    <TextBlock Text="Sent by" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="UnzipSentByText" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="5,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- HISTORY SECTION -->
            <Grid x:Name="HistorySection" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="28,20,28,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="History" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="HistoryCount" Text="" FontSize="12"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,3,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Clear all"
                            Style="{StaticResource GhostButtonStyle}"
                            Padding="12,6" FontSize="12" VerticalAlignment="Center"
                            Click="HistoryClear_Click"/>
                </Grid>
                <ScrollViewer Grid.Row="1" Margin="28,16,28,24"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ItemsControl x:Name="HistoryList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8"
                                            Background="{DynamicResource BgCardBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            Padding="14,10" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="32" Height="32"
                                                    CornerRadius="6" Margin="0,0,12,0"
                                                    Background="{DynamicResource BgPrimaryBrush}">
                                                <TextBlock Text="{Binding TypeIcon}"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="15"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding OutputPath}"
                                                           FontSize="12" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding FormattedTime}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="&#x203A;"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                                       Opacity="0.5"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="HistoryEmpty"
                                   Text="No operations yet."
                                   FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,8,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- VAULT SECTION -->
            <Grid x:Name="VaultSection" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="{DynamicResource HeroGradientBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid Margin="28,20,28,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Password Vault" FontSize="22" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="VaultSubtitle" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <!-- Cloud sync status badge -->
                        <Border x:Name="VaultSyncBadge" Grid.Column="1" CornerRadius="8"
                                Padding="10,5" VerticalAlignment="Center" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="VaultSyncIcon" FontFamily="Segoe MDL2 Assets"
                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock x:Name="VaultSyncLabel" FontSize="11" FontWeight="Medium"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Body -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="28,20,28,28">

                        <!-- Empty state -->
                        <Border x:Name="VaultEmptyState" CornerRadius="12"
                                Background="{DynamicResource BgCardBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Padding="32,40" Visibility="Collapsed">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="52" Height="52" CornerRadius="14"
                                        Background="{DynamicResource IconBgBlueBrush}"
                                        HorizontalAlignment="Center" Margin="0,0,0,14">
                                    <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="22" Foreground="#0071E3"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="No saved passwords yet" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Check 'Save password to this device' when creating a ZIP."
                                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Margin="0,6,0,16"
                                           TextAlignment="Center" TextWrapping="Wrap"/>
                                <Button Content="Go to Zip &amp; Encrypt"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Padding="16,8" FontSize="12" HorizontalAlignment="Center"
                                        Click="VaultGoToZip_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Entry list — populated from code-behind -->
                        <ItemsControl x:Name="VaultList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Margin="0,0,0,8"
                                            Background="{DynamicResource BgCardBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1">
                                        <Grid Margin="16,14">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="10"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Row 1: file info + delete -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="9"
                                                        Background="{DynamicResource IconBgBlueBrush}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"
                                                               FontSize="15" Foreground="#0071E3"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="13,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Hint}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                        <TextBlock Text="{Binding FormattedDate}" FontSize="10.5"
                                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                                        <!-- Cloud badge -->
                                                        <Border x:Name="EntryCloudBadge"
                                                                Visibility="{Binding CloudBadgeVisibility}"
                                                                CornerRadius="4" Padding="5,1" Margin="8,0,0,0"
                                                                Background="{DynamicResource IconBgBlueBrush}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets"
                                                                           FontSize="9" Foreground="#0071E3"
                                                                           VerticalAlignment="Center" Margin="0,0,3,0"/>
                                                                <TextBlock Text="{Binding CloudLabel}" FontSize="9"
                                                                           FontWeight="SemiBold" Foreground="#0071E3"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <!-- Local badge -->
                                                        <Border Visibility="{Binding LocalBadgeVisibility}"
                                                                CornerRadius="4" Padding="5,1" Margin="8,0,0,0"
                                                                Background="{DynamicResource BgPrimaryBrush}">
                                                            <TextBlock Text="Local" FontSize="9" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextMutedBrush}"/>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Button Grid.Column="2" Content="&#xE74D;"
                                                        FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Padding="6,4" VerticalAlignment="Center"
                                                        ToolTip="Delete saved password"
                                                        Tag="{Binding Key}"
                                                        Click="VaultDelete_Click"/>
                                            </Grid>

                                            <!-- Row 3: password row -->
                                            <Border Grid.Row="2" CornerRadius="8"
                                                    Background="{DynamicResource BgPrimaryBrush}"
                                                    Padding="12,9">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding PasswordDisplay}"
                                                               FontFamily="Consolas" FontSize="12.5"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Button Grid.Column="1"
                                                            Content="{Binding RevealLabel}"
                                                            Style="{StaticResource GhostButtonStyle}"
                                                            FontSize="11" Padding="8,3" Margin="8,0,0,0"
                                                            Tag="{Binding Key}"
                                                            Click="VaultReveal_Click"/>
                                                    <Button Grid.Column="2" Content="Copy"
                                                            Style="{StaticResource GhostButtonStyle}"
                                                            FontSize="11" Padding="8,3" Margin="4,0,0,0"
                                                            Tag="{Binding Key}"
                                                            Click="VaultCopy_Click"/>
                                                </Grid>
                                            </Border>

                                            <!-- Row 5: open/locate actions (hidden when neither path nor URL available) -->
                                            <StackPanel Grid.Row="4" Orientation="Horizontal">
                                                <!-- Open Location — local entries with a stored path -->
                                                <Button Visibility="{Binding OpenLocalBtnVisibility}"
                                                        IsEnabled="{Binding LocalFileExists}"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        FontSize="11" Padding="8,4" Margin="0,0,6,0"
                                                        ToolTip="{Binding OpenLocalTooltip}"
                                                        Tag="{Binding}"
                                                        Click="VaultOpenLocal_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        <TextBlock Text="Open Location" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <!-- Open in Drive — cloud entries with a share URL -->
                                                <Button Visibility="{Binding OpenCloudBtnVisibility}"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        FontSize="11" Padding="8,4" Margin="0,0,6,0"
                                                        ToolTip="{Binding CloudUrl}"
                                                        Tag="{Binding}"
                                                        Click="VaultOpenCloud_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        <TextBlock Text="Open in Drive" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- SETTINGS SECTION -->
            <ScrollViewer x:Name="SettingsSection" VerticalScrollBarVisibility="Auto"
                          Background="Transparent" Visibility="Collapsed">
                <StackPanel Margin="28,20,28,24">
                    <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

                    <!-- Pro Active badge — shown only when user is Pro -->
                    <Border x:Name="ProActiveCard" CornerRadius="10" Margin="0,0,0,14" Padding="18"
                            BorderThickness="1" BorderBrush="#22A34A" Visibility="Collapsed"
                            Background="{DynamicResource BannerSuccessBgBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="&#x2713;" FontSize="14" Foreground="#16A34A"
                                           VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBlock Text="Starkive Pro" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                <Border Background="#16A34A" CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                                    <TextBlock Text="ACTIVE" FontSize="9" FontWeight="Bold"
                                               Foreground="White" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" LineHeight="18"
                                       Margin="0,0,0,10">
                                Your Pro license is active. All features are unlocked.
                            </TextBlock>
                            <Button Content="View dashboard →" HorizontalAlignment="Left"
                                    FontSize="12" FontWeight="SemiBold"
                                    Foreground="White" Background="#16A34A"
                                    Padding="14,7" BorderThickness="0" Cursor="Hand"
                                    Click="ViewDashboard_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Pro upgrade card — hidden when user is already Pro -->
                    <Border x:Name="ProUpgradeCard" CornerRadius="10" Margin="0,0,0,14" Padding="18" BorderThickness="1"
                            Background="{DynamicResource BannerInfoBgBrush}">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#0071E3" Opacity="0.35"/>
                        </Border.BorderBrush>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="+" FontSize="13" Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Starkive Pro" FontSize="13"
                                           FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                                           Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="18">
                                Know the exact moment your files are opened, with proof they have not been tampered with.
                            </TextBlock>
                            <StackPanel Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Ellipse Width="4" Height="4" Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Open notifications with timestamp and country"
                                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="7,0,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Ellipse Width="4" Height="4" Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Tamper-proof .ssz secure container format"
                                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="7,0,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Ellipse Width="4" Height="4" Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="SHA-256 file integrity verification"
                                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="7,0,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="4" Height="4" Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Full audit history and delivery receipts"
                                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="7,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="$2.99" FontSize="18"
                                                   FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text=" / month" FontSize="12"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                    </StackPanel>
                                    <TextBlock Text="Cancel anytime  No commitment"
                                               FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Upgrade to Pro"
                                        FontSize="12" FontWeight="SemiBold"
                                        Foreground="White" Background="{DynamicResource AccentBrush}"
                                        Padding="16,8" BorderThickness="0" Cursor="Hand"
                                        Click="UpgradeToPro_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Appearance -->
                    <TextBlock Text="APPEARANCE" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextLabelBrush}" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Theme" FontSize="13" FontWeight="Medium"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="ThemeStatusText" Text="Light theme is active" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <ComboBox x:Name="ThemeComboBox" Grid.Column="1"
                                      Width="120" VerticalAlignment="Center"
                                      SelectionChanged="ThemeComboBox_SelectionChanged">
                                <ComboBoxItem Content="Dark"     Tag="Dark"     IsSelected="True"/>
                                <ComboBoxItem Content="Light"    Tag="Light"/>
                                <ComboBoxItem Content="Titanium" Tag="Titanium"/>
                                <ComboBoxItem Content="System"   Tag="System"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- Output folder -->
                    <TextBlock Text="OUTPUT FOLDER" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextLabelBrush}" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Default save location" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="DefaultFolderBox"
                                         Style="{StaticResource DarkTextBoxStyle}"
                                         IsReadOnly="True" Text="Same as source"/>
                                <Button Grid.Column="1" Content="Browse"
                                        Style="{StaticResource InlineButtonStyle}"
                                        Margin="6,0,0,0"
                                        Click="SettingsBrowseFolder_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Context menu -->
                    <TextBlock Text="CONTEXT MENU" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextLabelBrush}" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock x:Name="CtxMenuStatusText" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="18"/>
                            <Button x:Name="CtxMenuButton" Content="Install"
                                    Style="{StaticResource GhostButtonStyle}"
                                    HorizontalAlignment="Left" Padding="16,8" FontSize="12"
                                    Click="CtxMenu_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Cloud Backup -->
                    <TextBlock Text="CLOUD BACKUP" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextLabelBrush}" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="Sync saved passwords to cloud storage. Your vault is encrypted before upload — the cloud provider never sees your passwords."
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,14" LineHeight="18"/>
                            <!-- Google Drive row -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="6"
                                        Background="{DynamicResource IconBgBlueBrush}" Margin="0,0,10,0">
                                    <TextBlock Text="G" FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="#4285F4"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Google Drive" FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock x:Name="GDriveStatusText" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}" Text="Not connected"/>
                                </StackPanel>
                                <Button x:Name="GDriveButton" Grid.Column="2" Content="Connect"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Padding="12,6" FontSize="12" VerticalAlignment="Center"
                                        Margin="10,0,0,0" Click="GDriveButton_Click"/>
                            </Grid>
                            <!-- OneDrive row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="6"
                                        Background="{DynamicResource IconBgBlueBrush}" Margin="0,0,10,0">
                                    <TextBlock Text="OD" FontSize="11" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="#0078D4"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="OneDrive" FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock x:Name="OneDriveStatusText" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}" Text="Not connected"/>
                                </StackPanel>
                                <Button x:Name="OneDriveButton" Grid.Column="2" Content="Connect"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Padding="12,6" FontSize="12" VerticalAlignment="Center"
                                        Margin="10,0,0,0" Click="OneDriveButton_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border x:Name="CloudSetupWarning"
                            Background="{DynamicResource BannerWarnBgBrush}" BorderBrush="{DynamicResource WarnBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,18"
                            Visibility="Collapsed">
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" LineHeight="17">
                            <Run FontWeight="SemiBold">Setup required:</Run>
                            <Run>Register OAuth apps at console.cloud.google.com (Google) and portal.azure.com (Microsoft), paste the Client IDs into AppConstants.cs, then rebuild.</Run>
                        </TextBlock>
                    </Border>

                    <!-- App data -->
                    <TextBlock Text="APP DATA" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextLabelBrush}" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Data folder" FontSize="12" FontWeight="Medium"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="AppDataPathText" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Open"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Padding="12,6" FontSize="12" VerticalAlignment="Center"
                                    Margin="12,0,0,0" Click="OpenDataFolder_Click"/>
                        </Grid>
                    </Border>

                    <Button Content="Save Settings"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Right" Click="SaveSettings_Click"/>
                    <Border x:Name="SettingsSavedBanner"
                            Background="{DynamicResource BannerSuccessBgBrush}" BorderBrush="{DynamicResource SuccessBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="14,10"
                            Margin="0,10,0,0" HorizontalAlignment="Right"
                            Visibility="Collapsed">
                        <TextBlock Text="Settings saved." FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

        </Grid>

            </Grid><!-- /sections row 1 -->

        <!-- ── Toast notification (floats over both columns) ─────────────── -->
        <Border x:Name="ToastBorder"
                Grid.Column="0" Grid.ColumnSpan="2"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,24"
                Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="14,10"
                Visibility="Collapsed" IsHitTestVisible="False">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ToastTranslate" Y="0"/>
            </Border.RenderTransform>
            <TextBlock x:Name="ToastText"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="12" FontFamily="IBM Plex Sans, Segoe UI"/>
        </Border>

    </Grid>
</Window>




