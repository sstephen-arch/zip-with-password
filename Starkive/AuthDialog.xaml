<Window x:Class="Starkive.AuthDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Starkive Account"
        Width="400" Height="Auto" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0A0E16"
        Foreground="#E8F0FB"
        FontFamily="IBM Plex Sans, Segoe UI">

    <Window.Resources>
        <ResourceDictionary Source="Themes/AppResources.xaml"/>
    </Window.Resources>

    <StackPanel Margin="32,28,32,32">

        <!-- Logo + heading -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <Viewbox Width="20" Height="20" Margin="0,0,8,0">
                <Canvas Width="16" Height="16">
                    <Polygon Points="8,0 10.5,5.5 16,6.5 11.5,11 12.5,16 8,13.5 3.5,16 4.5,11 0,6.5 5.5,5.5"
                             Fill="#1A56DB"/>
                </Canvas>
            </Viewbox>
            <TextBlock Text="Starkive" FontSize="16" FontWeight="SemiBold"
                       Foreground="#E8F0FB" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock x:Name="SubheadingText" Text="Sign in to your account"
                   FontSize="12" Foreground="#3A5470" Margin="0,0,0,24"/>

        <!-- Email -->
        <TextBlock Text="EMAIL" FontSize="10" FontWeight="SemiBold"
                   Foreground="#3A5470" Margin="0,0,0,6"/>
        <Border Background="#0D1219" BorderBrush="#1E2D3F" BorderThickness="1"
                CornerRadius="6" Padding="12,0" Margin="0,0,0,14">
            <TextBox x:Name="EmailBox"
                     Background="Transparent" BorderThickness="0"
                     Foreground="#E8F0FB" FontSize="13"
                     Height="38" VerticalContentAlignment="Center"
                     CaretBrush="#1A56DB"/>
        </Border>

        <!-- Password -->
        <TextBlock Text="PASSWORD" FontSize="10" FontWeight="SemiBold"
                   Foreground="#3A5470" Margin="0,0,0,6"/>
        <Border Background="#0D1219" BorderBrush="#1E2D3F" BorderThickness="1"
                CornerRadius="6" Padding="12,0" Margin="0,0,0,6">
            <PasswordBox x:Name="PasswordBox"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#E8F0FB" FontSize="13"
                         Height="38" VerticalContentAlignment="Center"/>
        </Border>

        <!-- Confirm password (sign-up only) -->
        <Border x:Name="ConfirmRow" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="CONFIRM PASSWORD" FontSize="10" FontWeight="SemiBold"
                           Foreground="#3A5470" Margin="0,8,0,6"/>
                <Border Background="#0D1219" BorderBrush="#1E2D3F" BorderThickness="1"
                        CornerRadius="6" Padding="12,0" Margin="0,0,0,6">
                    <PasswordBox x:Name="ConfirmBox"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#E8F0FB" FontSize="13"
                                 Height="38" VerticalContentAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Error message -->
        <Border x:Name="ErrorBorder"
                Background="#1A0A0A" BorderBrush="#7C2D12" BorderThickness="1"
                CornerRadius="6" Padding="12,8" Margin="0,8,0,0"
                Visibility="Collapsed">
            <TextBlock x:Name="ErrorText" Foreground="#FCA47A" FontSize="12"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Primary button -->
        <Button x:Name="PrimaryBtn"
                Content="Sign In"
                Style="{StaticResource PrimaryButtonStyle}"
                Margin="0,20,0,0" Height="42" FontSize="13"
                Click="PrimaryBtn_Click"/>

        <!-- Toggle mode link -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,0">
            <TextBlock x:Name="ToggleLabel" Text="Don't have an account?"
                       FontSize="12" Foreground="#3A5470"/>
            <TextBlock x:Name="ToggleLink" Text=" Create one"
                       FontSize="12" Foreground="#1A56DB" Cursor="Hand"
                       MouseLeftButtonUp="ToggleMode_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
